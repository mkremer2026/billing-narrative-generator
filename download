      results: ["for initial case report and strategic recommendations","for summary judgment motion","for settlement negotiations","for mediation preparation","for trial preparation","for client status update and further handling","for motion to compel","for final case disposition","for dispositive motion practice","for case evaluation and liability assessment","for expert retention decision","for discovery response deadline","for pretrial conference","for appellate record preservation","for damages calculation","for litigation budget update","for witness preparation session","for early case resolution","for protective order application","for sanctions motion","for Rule 26 disclosures","for case management order compliance","for client reporting requirements"]
    },
    transactional: {
      label: "Transactional Attorney",
      actions: ["Review","Analyze","Evaluate","Strategize","Exchange","Prepare","Plan","Proceed","Draft","Audit","Appear","Outline","Coordinate","Assess","Revise","Request","Finalize","Update","Document","Identify","Facilitate","Implement","Develop","Verify"],
      tasks: ["Purchase Agreement","Merger Agreement","Stock Purchase Agreement","Asset Purchase Agreement","Securities Filings","Disclosure Schedules","Due Diligence Request List","Closing Checklist","Board Resolutions","Shareholder Consents","Officer's Certificates","Legal Opinions","Corporate Governance Documents","Regulatory Filings","Term Sheets","Due Diligence Review","Document Repository","Signature Pages","Closing Deliverables","Transaction Timeline","Deal Summary","Risk Assessment Matrix","Compliance Checklist"],
      values: ["to understand the legal precedents","to evaluate relevant statutes applicable to transaction","to mitigate potential risks","to maximize favorable outcomes","to identify potential risks","to satisfy conditions precedent","to assess legal accuracy and consistency","to determine potential impact of same","to minimize post-closing liability","to meet filing deadlines","to ensure regulatory compliance","to mitigate transaction risks","to optimize tax structure","to align with business objectives","to consider market standards","to facilitate timely closing","to protect client interests","to facilitate efficient closing","to maintain confidentiality","to streamline due diligence process","to enhance negotiating position","to ensure securities law compliance"],
