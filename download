<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --navy: #002147;
    --navy-deep: #001530;
    --navy-light: #0a3d7a;
    --gold: #CBA135;
    --gold-light: #e5c568;
    --gold-soft: #f7efd4;
    --ivory: #faf8f3;
    --cream: #f4eee1;
    --paper: #fefcf7;
    --charcoal: #1a1a1a;
    --muted: #6b7280;
    --border: rgba(0, 33, 71, 0.12);
    --shadow-sm: 0 1px 3px rgba(0, 33, 71, 0.08);
    --shadow-md: 0 4px 20px rgba(0, 33, 71, 0.08);
    --shadow-lg: 0 20px 60px rgba(0, 33, 71, 0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  .bnc-app {
    font-family: 'Outfit', sans-serif;
    color: var(--charcoal);
    line-height: 1.6;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--paper);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* ===== Header ===== */
  .bnc-header {
    background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 60%, var(--navy-light) 100%);
    color: var(--paper);
    padding: 3rem 2.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .bnc-header::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -15%;
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(203,161,53,0.22) 0%, transparent 65%);
    pointer-events: none;
  }

  .bnc-header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold) 70%, transparent);
  }

  .bnc-brand-line {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .bnc-brand-mark {
    width: 2.5rem;
    height: 1.5px;
    background: var(--gold);
  }

  .bnc-brand-tag {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.72rem;
    color: var(--gold);
    font-weight: 500;
  }

  .bnc-header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.1rem, 4vw, 3.2rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin-bottom: 0.85rem;
    position: relative;
    z-index: 1;
  }

  .bnc-header h1 em {
    color: var(--gold);
    font-style: italic;
    font-weight: 400;
  }

  .bnc-header p {
    font-size: 1.02rem;
    max-width: 620px;
    opacity: 0.85;
    position: relative;
    z-index: 1;
    font-weight: 300;
  }

  .bnc-header .bnc-signature {
    margin-top: 1.5rem;
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--gold-light);
    position: relative;
    z-index: 1;
  }

  /* ===== Main tabs ===== */
  .bnc-main-tabs {
    display: flex;
    background: var(--navy-deep);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .bnc-main-tab {
    flex: 1;
    padding: 1.1rem 1rem;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.55);
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    transition: color 0.2s ease;
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  .bnc-main-tab:last-child { border-right: none; }

  .bnc-main-tab:hover { color: rgba(255,255,255,0.9); }

  .bnc-main-tab.active {
    color: var(--gold);
    background: linear-gradient(180deg, rgba(203,161,53,0.05) 0%, transparent 100%);
  }

  .bnc-main-tab.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 40%; height: 2px;
    background: var(--gold);
  }

  .bnc-main-tab .bnc-tab-num {
    display: block;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.7rem;
    opacity: 0.5;
    margin-bottom: 0.25rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: none;
  }

  /* ===== Body ===== */
  .bnc-body {
    padding: 2.5rem 2.5rem 3rem;
    background: var(--paper);
  }

  .bnc-panel { display: none; }
  .bnc-panel.active { display: block; animation: fadeIn 0.35s ease; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .bnc-panel-intro {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .bnc-panel-intro h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }

  .bnc-panel-intro p {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 640px;
  }

  /* ===== Role selector ===== */
  .bnc-section-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold-dark, #a38527);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bnc-section-label::before {
    content: '';
    width: 1.25rem;
    height: 1.5px;
    background: var(--gold);
  }

  .bnc-role-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .bnc-role-btn {
    padding: 0.9rem 0.75rem;
    background: var(--ivory);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    color: var(--navy);
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
    line-height: 1.3;
  }

  .bnc-role-btn:hover {
    border-color: var(--gold);
    background: var(--paper);
  }

  .bnc-role-btn.active {
    background: var(--navy);
    color: var(--paper);
    border-color: var(--navy);
    box-shadow: 0 4px 12px rgba(0,33,71,0.25);
  }

  .bnc-role-btn .bnc-role-sub {
    display: block;
    font-size: 0.7rem;
    opacity: 0.65;
    margin-top: 0.2rem;
    font-weight: 400;
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  /* ===== Form ===== */
  .bnc-form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .bnc-form-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .bnc-field { display: flex; flex-direction: column; }

  .bnc-field label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.45rem;
    letter-spacing: 0.02em;
  }

  .bnc-field label .bnc-hint {
    font-weight: 400;
    color: var(--muted);
    font-size: 0.78rem;
    margin-left: 0.35rem;
    font-style: italic;
  }

  .bnc-input, .bnc-textarea {
    width: 100%;
    padding: 0.75rem 0.9rem;
    background: var(--ivory);
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    color: var(--charcoal);
    transition: border-color 0.2s ease, background 0.2s ease;
    resize: vertical;
  }

  .bnc-textarea { min-height: 96px; font-family: Georgia, serif; line-height: 1.55; }

  .bnc-input:focus, .bnc-textarea:focus {
    outline: none;
    border-color: var(--gold);
    background: var(--paper);
    box-shadow: 0 0 0 3px rgba(203,161,53,0.12);
  }

  /* ===== Time breakdown (bookends) ===== */
  .bnc-time-breakdown {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  /* ===== Guidelines drop section ===== */
  .bnc-guidelines {
    margin-top: 1.25rem;
    margin-bottom: 1.5rem;
    border: 1.5px dashed var(--border);
    border-radius: 8px;
    background: var(--ivory);
    overflow: hidden;
    transition: all 0.25s ease;
  }

  .bnc-guidelines.active { border-color: var(--gold); background: var(--gold-soft); }

  .bnc-guidelines-toggle {
    width: 100%;
    padding: 0.95rem 1.1rem;
    background: transparent;
    border: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--navy);
    text-align: left;
  }

  .bnc-guidelines-toggle-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bnc-guidelines-icon {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.95rem;
    font-family: 'Playfair Display', serif;
  }

  .bnc-chev {
    width: 12px; height: 12px;
    border-right: 2px solid var(--navy);
    border-bottom: 2px solid var(--navy);
    transform: rotate(45deg);
    transition: transform 0.25s ease;
  }

  .bnc-guidelines.open .bnc-chev { transform: rotate(-135deg); }

  .bnc-guidelines-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    padding: 0 1.1rem;
  }

  .bnc-guidelines.open .bnc-guidelines-body {
    max-height: 600px;
    padding: 0 1.1rem 1.1rem;
  }

  .bnc-guidelines-body p {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 0.85rem;
  }

  .bnc-file-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.85rem;
    border-top: 1px dashed var(--border);
  }

  .bnc-file-btn {
    padding: 0.55rem 0.95rem;
    background: var(--navy);
    color: var(--paper);
    border: none;
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .bnc-file-btn:hover { background: var(--navy-light); }

  .bnc-file-name {
    font-size: 0.82rem;
    color: var(--muted);
    font-style: italic;
  }

  .bnc-file-clear {
    margin-left: auto;
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.82rem;
    text-decoration: underline;
  }

  /* ===== Generate button ===== */
  .bnc-generate-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .bnc-generate-note {
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    font-family: 'Playfair Display', serif;
  }

  .bnc-generate-btn {
    padding: 0.85rem 2rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: var(--navy-deep);
    border: none;
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(203,161,53,0.35);
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .bnc-generate-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(203,161,53,0.45);
  }

  .bnc-generate-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .bnc-generate-btn::after {
    content: '→';
    font-family: Georgia, serif;
    font-size: 1.15rem;
    transition: transform 0.2s ease;
  }

  .bnc-generate-btn:hover:not(:disabled)::after { transform: translateX(3px); }

  .bnc-secondary-btn {
    padding: 0.85rem 1.25rem;
    background: transparent;
    color: var(--navy);
    border: 1.5px solid var(--navy);
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .bnc-secondary-btn:hover {
    background: var(--navy);
    color: var(--paper);
  }

  .bnc-secondary-btn.copied {
    background: var(--gold);
    color: var(--navy-deep);
    border-color: var(--gold);
  }

  .bnc-fallback-banner {
    padding: 1rem 1.1rem;
    background: var(--gold-soft);
    border: 1px solid rgba(203,161,53,0.4);
    border-left: 3px solid var(--gold);
    border-radius: 6px;
    font-size: 0.88rem;
    color: var(--navy);
    margin-top: 1rem;
    line-height: 1.5;
  }

  .bnc-fallback-banner strong { color: var(--navy-deep); }

  .bnc-fallback-banner .bnc-inline-btn {
    display: inline-block;
    margin-top: 0.6rem;
    padding: 0.45rem 0.9rem;
    background: var(--navy);
    color: var(--paper);
    border: none;
    border-radius: 4px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
  }

  .bnc-fallback-banner .bnc-inline-btn:hover { background: var(--navy-light); }
  .bnc-fallback-banner .bnc-inline-btn.copied { background: var(--gold); color: var(--navy-deep); }

  /* ===== Output ===== */
  .bnc-output {
    margin-top: 2rem;
    padding: 1.75rem;
    background: linear-gradient(180deg, var(--ivory) 0%, var(--paper) 100%);
    border-radius: 10px;
    border-left: 3px solid var(--gold);
    box-shadow: var(--shadow-sm);
    display: none;
  }

  .bnc-output.visible { display: block; animation: fadeIn 0.3s ease; }

  .bnc-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }

  .bnc-output-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    color: var(--navy);
    font-weight: 500;
  }

  .bnc-narrative-entry {
    margin-bottom: 1.1rem;
    padding: 1rem 1.15rem;
    background: var(--paper);
    border-radius: 6px;
    border: 1px solid var(--border);
    position: relative;
  }

  .bnc-narrative-entry:last-child { margin-bottom: 0; }

  .bnc-narrative-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bnc-narrative-time {
    color: var(--muted);
    font-weight: 400;
    font-style: italic;
    font-family: 'Playfair Display', serif;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .bnc-narrative-text {
    font-family: Georgia, serif;
    font-size: 1.02rem;
    color: var(--charcoal);
    line-height: 1.55;
  }

  .bnc-copy-btn {
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    cursor: pointer;
    color: var(--navy);
    transition: all 0.15s ease;
  }

  .bnc-copy-btn:hover { background: var(--navy); color: var(--paper); border-color: var(--navy); }

  /* ===== Loading state ===== */
  .bnc-loading {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--muted);
    font-style: italic;
    font-family: 'Playfair Display', serif;
  }

  .bnc-loading-dots {
    display: inline-block;
    margin-left: 0.25rem;
  }

  .bnc-loading-dots span {
    display: inline-block;
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    margin: 0 2px;
    animation: bounce 1.4s infinite ease-in-out;
  }

  .bnc-loading-dots span:nth-child(2) { animation-delay: 0.15s; }
  .bnc-loading-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.5; }
    40% { transform: translateY(-6px); opacity: 1; }
  }

  /* ===== Error ===== */
  .bnc-error {
    padding: 1rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    border-radius: 6px;
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  /* ===== Footer ===== */
  .bnc-footer {
    padding: 1.5rem 2.5rem;
    background: var(--navy-deep);
    color: rgba(255,255,255,0.6);
    text-align: center;
    font-size: 0.78rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    letter-spacing: 0.05em;
  }

  .bnc-footer span { color: var(--gold); font-style: normal; }

  /* ===== Framework reference chip ===== */
  .bnc-framework-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: var(--gold-soft);
    color: var(--navy);
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    border: 1px solid rgba(203,161,53,0.25);
  }

  .bnc-framework-badge .bnc-dot {
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
  }

  /* ===== Responsive ===== */
  @media (max-width: 720px) {
    .bnc-header { padding: 2.25rem 1.5rem 2.5rem; }
    .bnc-body { padding: 1.75rem 1.5rem 2rem; }
    .bnc-main-tab { font-size: 0.72rem; padding: 0.85rem 0.5rem; }
    .bnc-role-grid { grid-template-columns: 1fr 1fr; }
    .bnc-form-row { grid-template-columns: 1fr; }
    .bnc-generate-row { flex-direction: column; align-items: stretch; }
    .bnc-footer { padding: 1.25rem 1.5rem; }
  }
</style>

<div class="bnc-app">
  <!-- HEADER -->
  <header class="bnc-header">
    <div class="bnc-brand-line">
      <span class="bnc-brand-mark"></span>
      <span class="bnc-brand-tag">The Billing Coach</span>
    </div>
    <h1>The Billing <em>Narrative</em> Generator</h1>
    <p>Turn your completed work into partner-level billing narratives that capture the full value of your time — powered by the ATVR Framework.</p>
    <div class="bnc-signature">— Molly Kremer, Esq.</div>
  </header>

  <!-- MAIN TABS -->
  <nav class="bnc-main-tabs" role="tablist">
    <button class="bnc-main-tab active" data-panel="standard" role="tab">
      <span class="bnc-tab-num">i.</span>
      Standard Narrative
    </button>
    <button class="bnc-main-tab" data-panel="bookends" role="tab">
      <span class="bnc-tab-num">ii.</span>
      Billing Bookends
    </button>
    <button class="bnc-main-tab" data-panel="multiphase" role="tab">
      <span class="bnc-tab-num">iii.</span>
      Multi-Phase Work
    </button>
  </nav>

  <!-- BODY -->
  <div class="bnc-body">

    <!-- ============ PANEL 1: STANDARD ============ -->
    <section class="bnc-panel active" data-panel="standard">
      <div class="bnc-panel-intro">
        <span class="bnc-framework-badge"><span class="bnc-dot"></span>ATVR Framework · Action · Task · Value · Result</span>
        <h2>Single Narrative</h2>
        <p>Paste a blurb about a billable task you just completed. The generator will return a polished 20-25 word narrative using the full ATVR framework calibrated to your role.</p>
      </div>

      <div class="bnc-section-label">Select Your Role</div>
      <div class="bnc-role-grid" data-role-group="standard">
        <button class="bnc-role-btn active" data-role="litigator">Litigator<span class="bnc-role-sub">attorney</span></button>
        <button class="bnc-role-btn" data-role="transactional">Transactional<span class="bnc-role-sub">attorney</span></button>
        <button class="bnc-role-btn" data-role="lit-paralegal">Litigation<span class="bnc-role-sub">paralegal</span></button>
        <button class="bnc-role-btn" data-role="trans-paralegal">Transactional<span class="bnc-role-sub">paralegal</span></button>
      </div>

      <div class="bnc-form-grid">
