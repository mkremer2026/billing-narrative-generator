      <div class="bnc-narrative-entry">
        <div class="bnc-narrative-label"><span>ATVR Narrative</span>${timeLabel}</div>
        <div class="bnc-narrative-text">${escapeHtml(data.narrative || "")}</div>
      </div>
      ${data.compliance_note ? `<div style="font-size: 0.82rem; color: var(--muted); margin-top: 0.75rem; padding: 0.6rem 0.85rem; background: var(--gold-soft); border-radius: 4px;"><strong style="color: var(--navy);">Compliance:</strong> ${escapeHtml(data.compliance_note)}</div>` : ""}
      ${data.coaching_tip ? `<div style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 0.92rem; color: var(--navy); margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px dashed var(--border);">— ${escapeHtml(data.coaching_tip)}</div>` : ""}
    `;
  }

  // ============ BOOKENDS ============
  async function handleBookends(btn, mode) {
    const task = document.getElementById('bk-task').value.trim();
    const context = document.getElementById('bk-context').value.trim();
    const tBefore = document.getElementById('bk-time-before').value.trim();
    const tMain = document.getElementById('bk-time-main').value.trim();
    const tAfter = document.getElementById('bk-time-after').value.trim();
    if (!task) { alert("Please enter the main task/event."); return; }
    const role = state.role.bookends;
    const guidelines = getGuidelinesFor('bookends');

    const prompt = `You are assisting Molly Kremer, Esq. (The Billing Coach) in generating a Billing Bookends narrative set using her proprietary framework.

${renderBlueprint(role)}

THE BILLING BOOKENDS FRAMEWORK — three separate time entries that together capture the complete work cycle:

BEFORE BOOKEND — the strategic preparation/analysis done BEFORE the main event
  • Start with 2-3 action words, present tense ("Strategize and assess" / "Research and analyze" / "Review and evaluate")
  • Include a VALUE phrase showing the prep's purpose
  • End with explicit connection to the upcoming task ("in advance of..." / "in preparation for..." / "prior to...")
  • 12-18 words

TASK / MAIN EVENT — the actual discrete task
  • Start with action describing the task ("Telephone conference with..." / "Attend and participate in..." / "Draft and revise...")
  • Include WHO is involved if applicable (client, co-counsel, opposing counsel)
  • Describe what was accomplished or discussed
  • Use "regarding" to introduce topics for conferences/calls
  • 12-18 words

AFTER BOOKEND — the strategic follow-up/implementation AFTER the main event
  • Start with 2-3 action words, present tense ("Evaluate and determine" / "Assess and prioritize" / "Analyze and implement")
  • Reference outputs from the task ("conference notes" / "research findings" / "client feedback")
  • Include forward-looking impact (next steps, strategy refinement, risk assessment)
  • 12-18 words

USER'S INPUT:
Main task/event: "${task}"
${context ? `Context: ${context}` : ""}
Times: BEFORE ${tBefore || "__"} · TASK ${tMain || "__"} · AFTER ${tAfter || "__"}

${guidelines.text || guidelines.file ? `CLIENT BILLING GUIDELINES (the three narratives MUST comply with these rules — watch for prohibited language, minimum increments, block billing restrictions):
${guidelines.text || "[See attached PDF]"}` : ""}

CRITICAL:
✓ ONLY present tense throughout all three entries
✓ No administrative language — emphasize strategic thinking and legal judgment
✓ Each bookend demonstrates SUBSTANTIAL intellectual work
✓ All three entries work together as a cohesive narrative of the complete work cycle

Return your response as JSON only, no preamble or code fences:
{
  "before": "narrative for before bookend",
  "main": "narrative for main task",
  "after": "narrative for after bookend",
  "compliance_note": "one sentence — compliant with guidelines or specific flag. If no guidelines: 'No client guidelines provided.'",
  "coaching_tip": "one short sentence in Molly's voice about why this bookend set captures the full work cycle"
}`;

    if (mode === 'copy') return copyPromptToClipboard(btn, prompt, 'bookends');
    await runGeneration(btn, 'bookends', prompt, guidelines.file, (data) => renderBookends(data, tBefore, tMain, tAfter));
  }

  function renderBookends(data, tB, tM, tA) {
    return `
      <div class="bnc-narrative-entry">
        <div class="bnc-narrative-label"><span>Before Bookend</span>${tB ? `<span class="bnc-narrative-time">${tB} hrs</span>` : ""}</div>
        <div class="bnc-narrative-text">${escapeHtml(data.before || "")}</div>
      </div>
      <div class="bnc-narrative-entry">
        <div class="bnc-narrative-label"><span>Task · Main Event</span>${tM ? `<span class="bnc-narrative-time">${tM} hrs</span>` : ""}</div>
        <div class="bnc-narrative-text">${escapeHtml(data.main || "")}</div>
      </div>
      <div class="bnc-narrative-entry">
        <div class="bnc-narrative-label"><span>After Bookend</span>${tA ? `<span class="bnc-narrative-time">${tA} hrs</span>` : ""}</div>
        <div class="bnc-narrative-text">${escapeHtml(data.after || "")}</div>
      </div>
      ${data.compliance_note ? `<div style="font-size: 0.82rem; color: var(--muted); margin-top: 0.75rem; padding: 0.6rem 0.85rem; background: var(--gold-soft); border-radius: 4px;"><strong style="color: var(--navy);">Compliance:</strong> ${escapeHtml(data.compliance_note)}</div>` : ""}
      ${data.coaching_tip ? `<div style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 0.92rem; color: var(--navy); margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px dashed var(--border);">— ${escapeHtml(data.coaching_tip)}</div>` : ""}
    `;
  }

  // ============ MULTI-PHASE ============
  async function handleMultiphase(btn, mode) {
    const task = document.getElementById('mp-task').value.trim();
    const context = document.getElementById('mp-context').value.trim();
    const time = document.getElementById('mp-time').value.trim();
    const split = document.getElementById('mp-split').value.trim();
    if (!task) { alert("Please describe the work."); return; }
    const role = state.role.multiphase;
    const guidelines = getGuidelinesFor('multiphase');

    const prompt = `You are assisting Molly Kremer, Esq. (The Billing Coach) in generating a Multi-Phase Legal Work billing narrative set using her proprietary ATVR framework.

${renderBlueprint(role)}

THE MULTI-PHASE FRAMEWORK — four SEPARATE billing narratives (NOT block billed) that break one project into distinct phases. Each narrative:
✓ 20-25 words total
✓ ONLY present tense
✓ Starts with 2-3 ACTION words strung together
✓ Includes the TASK NAME in every single narrative (e.g., "motion to dismiss" appears in all four)
✓ Includes VALUE phrase (what this phase accomplishes for the client)
✓ Includes EXTRA VALUE or RESULT phrase when applicable
✓ Sounds like attorney-level (or seasoned paralegal) work
✓ Avoids administrative language used alone

REQUIRED PHASES:
1. REVIEW / ANALYZE PHASE — initial assessment, case law research, document review, strategic analysis
2. OUTLINING / STRATEGY PHASE — strategic planning, argument development, approach formulation
3. PREPARATION / DRAFTING PHASE — substantive drafting, preparation, creation work
4. FINALIZING / REVIEW PHASE — quality control, strategic refinement, completion

USER'S INPUT:
Work description: "${task}"
${context ? `Context: ${context}` : ""}
Total time: ${time || "[not specified]"}${split ? `\nUser-specified phase split: ${split}` : "\nPhase split: auto-distribute the total time across the four phases sensibly (heavier on drafting typically)"}

${guidelines.text || guidelines.file ? `CLIENT BILLING GUIDELINES (all four narratives MUST comply — watch for prohibited verbs, block billing rules, minimum increments, task-specific restrictions):
${guidelines.text || "[See attached PDF]"}` : ""}

CRITICAL:
✓ Every phase demonstrates SUBSTANTIAL intellectual work
✓ TASK NAME appears in every single narrative
✓ Times should add up to the total provided
✓ Each entry stands alone as a complete billing narrative
✓ Partner-level sophistication in language

Return your response as JSON only, no preamble or code fences:
{
  "phase1": {"narrative": "...", "time": "e.g., 1.5"},
  "phase2": {"narrative": "...", "time": "..."},
  "phase3": {"narrative": "...", "time": "..."},
  "phase4": {"narrative": "...", "time": "..."},
  "compliance_note": "one sentence — compliant with guidelines or specific flag. If no guidelines: 'No client guidelines provided.'",
  "coaching_tip": "one short sentence in Molly's voice about why unbundling this work captures its full value"
}`;

    if (mode === 'copy') return copyPromptToClipboard(btn, prompt, 'multiphase');
    await runGeneration(btn, 'multiphase', prompt, guidelines.file, renderMultiphase);
  }

  function renderMultiphase(data) {
    const phaseLabels = ["Phase 1 · Review / Analyze", "Phase 2 · Outlining / Strategy", "Phase 3 · Preparation / Drafting", "Phase 4 · Finalizing / Review"];
    const phases = [data.phase1, data.phase2, data.phase3, data.phase4];
    let html = "";
    phases.forEach((p, i) => {
      if (!p) return;
      html += `
        <div class="bnc-narrative-entry">
          <div class="bnc-narrative-label"><span>${phaseLabels[i]}</span>${p.time ? `<span class="bnc-narrative-time">${escapeHtml(p.time)} hrs</span>` : ""}</div>
          <div class="bnc-narrative-text">${escapeHtml(p.narrative || "")}</div>
        </div>
      `;
    });
    if (data.compliance_note) html += `<div style="font-size: 0.82rem; color: var(--muted); margin-top: 0.75rem; padding: 0.6rem 0.85rem; background: var(--gold-soft); border-radius: 4px;"><strong style="color: var(--navy);">Compliance:</strong> ${escapeHtml(data.compliance_note)}</div>`;
    if (data.coaching_tip) html += `<div style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 0.92rem; color: var(--navy); margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px dashed var(--border);">— ${escapeHtml(data.coaching_tip)}</div>`;
    return html;
  }

  // ============ GENERATION RUNNER ============
  async function runGeneration(btn, panel, prompt, file, renderFn) {
    const outputEl = document.querySelector(`[data-output="${panel}"]`);
    const originalBtnText = btn.textContent;
    btn.disabled = true;
    btn.textContent = "Generating...";

    outputEl.classList.add('visible');
    outputEl.innerHTML = `
      <div class="bnc-loading">
        Molly's framework is drafting your narrative<span class="bnc-loading-dots"><span></span><span></span><span></span></span>
      </div>
    `;

    try {
      // Build message content
      let content;
      if (file) {
        content = [
          { type: "document", source: { type: "base64", media_type: "application/pdf", data: file.data } },
          { type: "text", text: prompt }
        ];
      } else {
        content = prompt;
      }

      const response = await fetch("/api/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: [{ role: "user", content }]
        })
      });

      if (!response.ok) {
        let errJson = {};
        try { errJson = await response.json(); } catch (_) {}
        throw new Error(errJson.error || `Server returned ${response.status}`);
      }
      const apiData = await response.json();

      // Extract text from response
      const rawText = apiData.content
        .filter(b => b.type === "text")
        .map(b => b.text)
        .join("\n")
        .trim();

      // Strip code fences if present
      const cleaned = rawText.replace(/^```(?:json)?\s*/i, "").replace(/\s*```\s*$/, "").trim();
      const data = JSON.parse(cleaned);

      // Render output
      outputEl.innerHTML = `
        <div class="bnc-output-header">
          <div class="bnc-output-title">Your Narrative${panel === 'standard' ? "" : " Set"}</div>
          <button class="bnc-copy-btn" data-copy-all>Copy All</button>
        </div>
        <div data-narratives>${renderFn(data)}</div>
      `;

      // Attach copy handler
      const copyBtn = outputEl.querySelector('[data-copy-all]');
      copyBtn.addEventListener('click', () => {
        const text = extractTextForCopy(data, panel);
        navigator.clipboard.writeText(text).then(() => {
          copyBtn.textContent = "✓ Copied";
          setTimeout(() => { copyBtn.textContent = "Copy All"; }, 2000);
        });
      });
    } catch (err) {
      console.error(err);
      const errorMsg = err.message || String(err);
      outputEl.innerHTML = `
        <div class="bnc-fallback-banner">
          <strong>Something didn't land.</strong> ${escapeHtml(errorMsg)}
          <br><br>
          Try again in a moment. If the error mentions rate limits, wait a few minutes. If it persists, you can copy the prompt below and paste it into any Claude chat as a backup.
          <br>
          <button class="bnc-inline-btn" data-fallback-copy>Copy Prompt to Clipboard</button>
        </div>
      `;
      const copyBtn = outputEl.querySelector('[data-fallback-copy]');
      copyBtn.addEventListener('click', async () => {
        let finalPrompt = prompt;
        if (file) {
          finalPrompt = `[NOTE: You also attached a PDF called "${file.name}" with client billing guidelines. Before pasting this into Claude, upload that same PDF into the Claude chat along with this prompt.]\n\n${prompt}`;
        }
        try {
          await navigator.clipboard.writeText(finalPrompt);
          copyBtn.textContent = "✓ Copied — paste into Claude";
          copyBtn.classList.add('copied');
        } catch (e) {
          copyBtn.textContent = "Could not copy — please try manually";
        }
      });
    } finally {
      btn.disabled = false;
      btn.textContent = originalBtnText;
    }
  }

  function extractTextForCopy(data, panel) {
    if (panel === 'standard') return data.narrative || "";
    if (panel === 'bookends') return `BEFORE: ${data.before || ""}\nTASK: ${data.main || ""}\nAFTER: ${data.after || ""}`;
    if (panel === 'multiphase') {
      const labels = ["PHASE 1 (Review/Analyze)", "PHASE 2 (Outlining/Strategy)", "PHASE 3 (Preparation/Drafting)", "PHASE 4 (Finalizing/Review)"];
      return [data.phase1, data.phase2, data.phase3, data.phase4]
        .map((p, i) => p ? `${labels[i]}${p.time ? ` [${p.time} hrs]` : ""}: ${p.narrative || ""}` : "")
        .filter(Boolean)
        .join("\n\n");
    }
    return "";
  }

  function escapeHtml(str) {
    if (!str) return "";
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
})();
</script>
