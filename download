      actions: ["Review","Organize","Compile","Index","Summarize","Redact","Assemble","Prepare","Draft","Create","Format","Cite-check","Proofread","Catalog","Coordinate","Track","Update","Maintain","Request","Collect","Extract"],
      tasks: ["Court Filings","Service of Process","Expert Materials","Hearing Binders","Settlement Documents","Status Reports","Case Files","Discovery Responses","Production Documents","Privilege Logs","Deposition Notices","Subpoenas","Chronologies","Document Database","Deposition Summaries","Exhibit Lists","Witness Lists","Correspondence","Pleadings","Motions"],
      values: ["to ensure timely court filing","to facilitate efficient case management","to support attorney preparation","to maintain accurate case records","to meet discovery deadlines","to support litigation strategy","to maintain case organization","to facilitate trial preparation","to ensure proper service of process","to protect confidential information","to expedite case resolution","to maintain professional standards","to support settlement negotiations","to ensure complete case documentation","to facilitate attorney review","to meet court-imposed deadlines","as requested by attorney/partner","to enhance case presentation","to verify legal citations","to ensure accuracy of filings"],
      results: ["for discovery deadline compliance","for attorney document review","for discovery response production","for witness scheduling coordination","for third-party document production","for case timeline development","for mediation/settlement conference","for litigation status reporting","for court submission deadline","for proof of service filing","for expert deposition preparation","for hearing presentation","for client status update","for case management compliance","for deposition digest completion","for pretrial submission deadline","for trial exhibit identification","for client/court communication","for motion/brief filing","for appellate record preservation"]
    },
    "trans-paralegal": {
      label: "Transactional Paralegal",
      actions: ["Review","Prepare","Organize","Compile","Index","Summarize","Assemble","Catalog","Draft","Create","Format","Proofread","Verify","Coordinate","Track","Maintain","Request","Collect","Compare","Reconcile","Circulate","Archive"],
      tasks: ["Signature Pages","Closing Binders","Due Diligence Checklists","Data Room Documents","Contract Terms","Transaction Bibles","Closing Deliverables","Corporate Resolutions","Board Consents","Entity Formation Documents","Disclosure Schedules","Officer's Certificates","Signing Authority","State Filings","Closing Conditions","Transaction Timelines","Corporate Records","Good Standing Certificates","Executed Documents","Agreement Versions","Deal Documents","Post-Closing Documents"],
      values: ["to ensure proper execution","to facilitate efficient transaction","to support attorney preparation","to organize for deal team access","to identify key provisions","to create permanent deal record","to track completion status","to document board approval","to authorize transaction","to establish new entity","to meet court-imposed deadlines","to verify corporate authority","to confirm execution authority","to ensure regulatory compliance","to monitor outstanding items","to maintain current deal status","to ensure accurate records","to verify entity good standing","to confirm proper execution","to identify negotiated changes","to verify accurate funds transfer","to obtain party approval","to facilitate buyer review","to preserve transaction records"],
      results: ["for closing execution","for permanent transaction archive","for due diligence completion","for deal team coordination","for contract analysis","for client reference","for closing checklist compliance","for post-closing compliance","for board approval documentation","for closing condition satisfaction","for state filing submission","for purchase agreement exhibit","for closing deliverable package","for signature coordination","for entity compliance","for closing readiness","for deal team reporting","for corporate record book","for closing condition verification","for closing binder assembly","for attorney markup review","for funds transfer completion","for transaction progression","for due diligence period"]
    }
  };

  // ============ STATE ============
  const state = {
    role: { standard: "litigator", bookends: "litigator", multiphase: "litigator" },
    guidelinesFile: { standard: null, bookends: null, multiphase: null }
  };

  // ============ TAB SWITCHING ============
  document.querySelectorAll('.bnc-main-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.dataset.panel;
      document.querySelectorAll('.bnc-main-tab').forEach(b => b.classList.toggle('active', b === btn));
      document.querySelectorAll('.bnc-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === panel));
    });
  });

  // ============ ROLE SELECTION ============
  document.querySelectorAll('[data-role-group]').forEach(group => {
    const panel = group.dataset.roleGroup;
    group.querySelectorAll('.bnc-role-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        group.querySelectorAll('.bnc-role-btn').forEach(b => b.classList.toggle('active', b === btn));
        state.role[panel] = btn.dataset.role;
      });
    });
  });

  // ============ GUIDELINES TOGGLE + FILE ============
  document.querySelectorAll('.bnc-guidelines').forEach(container => {
    const panel = container.dataset.guidelines;
    const toggle = container.querySelector('.bnc-guidelines-toggle');
    const fileTrigger = container.querySelector('[data-file-trigger]');
    const fileInput = container.querySelector('[data-file-input]');
    const fileName = container.querySelector('[data-file-name]');
    const fileClear = container.querySelector('[data-file-clear]');
    const textArea = container.querySelector('[data-guidelines-text]');

    toggle.addEventListener('click', () => {
      container.classList.toggle('open');
    });

    fileTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      fileInput.click();
    });

    fileInput.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      if (file.size > 10 * 1024 * 1024) {
        alert("PDF is larger than 10MB. Please use a smaller file or paste the relevant excerpts into the text box instead.");
        fileInput.value = "";
        return;
      }
      fileName.textContent = file.name;
      fileClear.style.display = "inline";
      container.classList.add('active');
      // convert to base64 and stash
      const b64 = await toBase64(file);
      state.guidelinesFile[panel] = { name: file.name, data: b64 };
    });

    fileClear.addEventListener('click', (e) => {
      e.stopPropagation();
      fileInput.value = "";
      fileName.textContent = "No file attached";
      fileClear.style.display = "none";
      state.guidelinesFile[panel] = null;
      if (!textArea.value.trim()) container.classList.remove('active');
    });

    textArea.addEventListener('input', () => {
      if (textArea.value.trim() || state.guidelinesFile[panel]) {
        container.classList.add('active');
      } else {
        container.classList.remove('active');
      }
    });
  });

  function toBase64(file) {
    return new Promise((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(r.result.split(",")[1]);
      r.onerror = () => reject(new Error("Could not read file"));
      r.readAsDataURL(file);
    });
  }

  // ============ GENERATE BUTTONS ============
  document.querySelectorAll('[data-generate]').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.dataset.generate;
      if (panel === 'standard') handleStandard(btn, 'generate');
      else if (panel === 'bookends') handleBookends(btn, 'generate');
      else if (panel === 'multiphase') handleMultiphase(btn, 'generate');
    });
  });

  // ============ COPY-PROMPT BUTTONS (fallback path) ============
  document.querySelectorAll('[data-copy-prompt]').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.dataset.copyPrompt;
      if (panel === 'standard') handleStandard(btn, 'copy');
      else if (panel === 'bookends') handleBookends(btn, 'copy');
      else if (panel === 'multiphase') handleMultiphase(btn, 'copy');
    });
  });

  async function copyPromptToClipboard(btn, prompt, panel) {
    const guidelines = getGuidelinesFor(panel);
    let finalPrompt = prompt;
    if (guidelines.file) {
      finalPrompt = `[NOTE: You also attached a PDF called "${guidelines.file.name}" with client billing guidelines. Before pasting this into Claude, upload that same PDF into the Claude chat along with this prompt.]\n\n${prompt}`;
    }
    try {
      await navigator.clipboard.writeText(finalPrompt);
      const originalText = btn.textContent;
      btn.textContent = "✓ Copied — paste into Claude";
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = originalText;
        btn.classList.remove('copied');
      }, 3000);
    } catch (err) {
      alert("Could not copy to clipboard automatically. Here's your prompt — copy it manually:\n\n" + finalPrompt.slice(0, 200) + "...");
    }
  }

  function getGuidelinesFor(panel) {
    const container = document.querySelector(`[data-guidelines="${panel}"]`);
    const text = container.querySelector('[data-guidelines-text]').value.trim();
    const file = state.guidelinesFile[panel];
    return { text, file };
  }

  function renderBlueprint(role) {
    const bp = BLUEPRINTS[role];
    return `Role: ${bp.label}

Reference pools from Molly Kremer's ATVR Billing Blueprint for this role (use these as inspiration — select the most appropriate terms for the specific task; do not force them if another phrasing is more accurate):

ACTION verbs: ${bp.actions.join(", ")}

TASK nouns: ${bp.tasks.join(", ")}

VALUE phrases: ${bp.values.join(" · ")}

RESULT phrases: ${bp.results.join(" · ")}`;
  }

  // ============ STANDARD ============
  async function handleStandard(btn, mode) {
    const task = document.getElementById('std-task').value.trim();
    const context = document.getElementById('std-context').value.trim();
    const time = document.getElementById('std-time').value.trim();
    if (!task) { alert("Please describe the task you completed."); return; }
    const role = state.role.standard;
    const guidelines = getGuidelinesFor('standard');

    const prompt = `You are assisting Molly Kremer, Esq. (The Billing Coach) in generating a billing narrative using her proprietary ATVR Framework.

${renderBlueprint(role)}

THE ATVR FRAMEWORK — 4 parts:
• ACTION — what you are doing (2-3 action verbs strung together, present tense only)
• TASK — what you are doing it for (named specifically)
• VALUE — why it matters / the purpose of the focus
• RESULT — the end goal: the deliverable, milestone, or strategic objective the work drives toward

USER'S WORK BLURB:
"${task}"
${context ? `\nMATTER CONTEXT: ${context}` : ""}
${time ? `\nTIME: ${time} hours` : ""}

${guidelines.text || guidelines.file ? `CLIENT BILLING GUIDELINES (carrier-specific rules that the narrative MUST comply with — check for prohibited verbs, block billing rules, minimum increments, prohibited tasks, and any special language requirements):
${guidelines.text || "[See attached PDF]"}` : ""}

OUTPUT REQUIREMENTS:
✓ 20-25 words total
✓ ONLY present tense
✓ Begin with 2-3 action words strung together (e.g., "Review and analyze" / "Strategize and draft" / "Assess and revise")
✓ Include the specific TASK name
✓ Include a VALUE phrase explaining why it matters
✓ Include a RESULT phrase showing what the work drives toward
✓ Sound like attorney-level (or seasoned paralegal) work — strategic, not clerical
✓ Avoid administrative verbs used alone ("organize," "gather," "compile" with no strategic context)
✓ If client guidelines were provided, strictly comply with them

Return your response as JSON only, no preamble or code fences:
{
  "narrative": "the 20-25 word narrative here",
  "compliance_note": "one short sentence — either 'Compliant with provided guidelines.' or a specific flag if something in the blurb conflicts with a rule you can see. If no guidelines were provided, write 'No client guidelines provided.'",
  "coaching_tip": "one short sentence in Molly's voice with a tip about why this narrative reads as valuable"
}`;

    if (mode === 'copy') return copyPromptToClipboard(btn, prompt, 'standard');
    await runGeneration(btn, 'standard', prompt, guidelines.file, renderStandard);
  }

  function renderStandard(data, time) {
    const timeLabel = time ? `<span class="bnc-narrative-time">${time} hrs</span>` : "";
